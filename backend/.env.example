# L5Music Backend Configuration

# Port the backend runs on
PORT=3002

# Absolute path to your music folder
MUSIC_DIR=/home/youruser/music

# Your public domain (used in signup/invite emails)
# Leave empty for LAN-only use
DOMAIN=

# Optional: Gmail credentials for signup email notifications
# Requires a Google App Password (not your regular password)
GMAIL_USER=
GMAIL_PASS=
